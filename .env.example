# ============================================================
# Энсо — переменные окружения
# Скопируйте этот файл в .env и заполните своими значениями
# ============================================================

# --- База данных PostgreSQL (локальная) -----------------------
DATABASE_URL=postgres://postgres:cd5d56a8@localhost:5432/enso

# --- Сервер ---------------------------------------------------
NODE_ENV=production
PORT=3000

# Включает Secure-cookie для сессий (нужно при работе по HTTPS)
HTTPS=true

# Секрет для подписи сессионных cookies — длинная случайная строка
# Сгенерировать: openssl rand -hex 48
SESSION_SECRET=CHANGE_ME_TO_RANDOM_LONG_STRING
